# Tachibana e支店 dev auto-login (debug build only).
# These variables are read ONLY when:
#   1. The Rust build is `debug` (release builds gate this off via
#      `dev_tachibana_login_allowed=false` in the stdin payload), AND
#   2. The variables are present and non-empty.
#
# Copy this file to `.env` and fill in your dev / demo account values.
# `.env` itself is gitignored — never commit credentials.
DEV_TACHIBANA_USER_ID=
DEV_TACHIBANA_PASSWORD=
DEV_TACHIBANA_DEMO=true

# Second password for order E2E tests (dev fast path only).
# Only used when FLOWSURFACE_DEV_TACHIBANA_LOGIN_ALLOWED=1.
# Leave empty to use the iced modal (normal operation).
DEV_TACHIBANA_SECOND_PASSWORD=


## J-Quants cache location for backtest data
# Required for backtest_example.py (and potentially SMA cross if you add backtest mode later)
# Create this directory if it doesn't exist
DEV_J_QUANTS_CACHE="S:/j-quants"

## replay デフォルト銘柄・期間（buy_and_hold.py サンプル用）
# run-replay-debug.sh および VSCode "replay" タスクから読み込まれる
REPLAY_INSTRUMENT_ID=1301.TSE
REPLAY_START_DATE=2025-01-06
REPLAY_END_DATE=2025-03-31
REPLAY_GRANULARITY=Daily
