{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowsurface/ipc/events",
  "title": "Python → Rust IPC Events",
  "description": "Events sent from the Python data engine to the Rust viewer. Schema MAJOR=2.",
  "oneOf": [
    { "$ref": "#/$defs/Ready" },
    { "$ref": "#/$defs/EngineError" },
    { "$ref": "#/$defs/Pong" },
    { "$ref": "#/$defs/Connected" },
    { "$ref": "#/$defs/Disconnected" },
    { "$ref": "#/$defs/Trades" },
    { "$ref": "#/$defs/TradesFetched" },
    { "$ref": "#/$defs/KlineUpdate" },
    { "$ref": "#/$defs/Klines" },
    { "$ref": "#/$defs/DepthSnapshot" },
    { "$ref": "#/$defs/DepthDiff" },
    { "$ref": "#/$defs/DepthGap" },
    { "$ref": "#/$defs/OpenInterest" },
    { "$ref": "#/$defs/TickerInfo" },
    { "$ref": "#/$defs/TickerStats" },
    { "$ref": "#/$defs/Error" },
    { "$ref": "#/$defs/VenueReady" },
    { "$ref": "#/$defs/VenueError" },
    { "$ref": "#/$defs/VenueLoginStarted" },
    { "$ref": "#/$defs/VenueLoginCancelled" },
    { "$ref": "#/$defs/SecondPasswordRequired" },
    { "$ref": "#/$defs/OrderSubmitted" },
    { "$ref": "#/$defs/OrderAccepted" },
    { "$ref": "#/$defs/OrderRejected" },
    { "$ref": "#/$defs/OrderPendingUpdate" },
    { "$ref": "#/$defs/OrderPendingCancel" },
    { "$ref": "#/$defs/OrderFilled" },
    { "$ref": "#/$defs/OrderCanceled" },
    { "$ref": "#/$defs/OrderExpired" },
    { "$ref": "#/$defs/OrderListUpdated" },
    { "$ref": "#/$defs/BuyingPowerUpdated" },
    { "$ref": "#/$defs/PositionsUpdated" }
  ],
  "$defs": {
    "RequestId": {
      "description": "UUIDv4 string per RFC 4122 (LOW-1 / F-L7). Python emits via str(uuid.uuid4()) — hyphenated lowercase.",
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "maxLength": 36
    },
    "RequestIdNullable": {
      "description": "Nullable variant of RequestId (used for events that may correlate to a request or be unsolicited).",
      "oneOf": [
        { "$ref": "#/$defs/RequestId" },
        { "type": "null" }
      ]
    },
    "Pong": {
      "type": "object",
      "required": ["op", "request_id"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "Pong" },
        "request_id": { "type": "string" }
      }
    },
    "Ready": {
      "type": "object",
      "required": ["event", "schema_major", "schema_minor", "engine_version", "engine_session_id", "capabilities"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "Ready" },
        "schema_major": { "type": "integer", "minimum": 0 },
        "schema_minor": { "type": "integer", "minimum": 0 },
        "engine_version": { "type": "string" },
        "engine_session_id": { "type": "string", "format": "uuid" },
        "capabilities": {
          "type": "object",
          "properties": {
            "supported_venues": {
              "type": "array",
              "items": { "type": "string" }
            },
            "supports_bulk_trades": { "type": "boolean" },
            "supports_depth_binary": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      }
    },
    "EngineError": {
      "type": "object",
      "required": ["event", "code", "message"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "EngineError" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "Connected": {
      "description": "Exchange WebSocket stream connected (mirrors exchange::Event::Connected).",
      "type": "object",
      "required": ["event", "venue", "ticker", "stream"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "Connected" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream": { "type": "string" }
      }
    },
    "Disconnected": {
      "description": "Exchange WebSocket stream disconnected (mirrors exchange::Event::Disconnected). For Tachibana, `reason: \"market_closed\"` indicates the JST trading session boundary.",
      "type": "object",
      "required": ["event", "venue", "ticker", "stream"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "Disconnected" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream": { "type": "string" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "TradeMsg": {
      "type": "object",
      "required": ["price", "qty", "side", "ts_ms"],
      "additionalProperties": false,
      "properties": {
        "price": { "type": "string" },
        "qty": { "type": "string" },
        "side": { "type": "string", "enum": ["buy", "sell"] },
        "ts_ms": { "type": "integer" },
        "is_liquidation": { "type": "boolean", "default": false }
      }
    },
    "Trades": {
      "type": "object",
      "required": ["event", "venue", "ticker", "stream_session_id", "trades"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "Trades" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream_session_id": { "type": "string" },
        "trades": {
          "type": "array",
          "items": { "$ref": "#/$defs/TradeMsg" }
        }
      }
    },
    "TradesFetched": {
      "description": "Chunked response to FetchTrades. is_last=true marks the final (or only) chunk.",
      "type": "object",
      "required": ["event", "request_id", "venue", "ticker", "trades", "is_last"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "TradesFetched" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "trades": {
          "type": "array",
          "items": { "$ref": "#/$defs/TradeMsg" }
        },
        "is_last": { "type": "boolean" }
      }
    },
    "KlineMsg": {
      "type": "object",
      "required": ["open_time_ms", "open", "high", "low", "close", "volume", "is_closed"],
      "additionalProperties": false,
      "properties": {
        "open_time_ms": { "type": "integer" },
        "open": { "type": "string" },
        "high": { "type": "string" },
        "low": { "type": "string" },
        "close": { "type": "string" },
        "volume": { "type": "string" },
        "is_closed": { "type": "boolean" }
      }
    },
    "KlineUpdate": {
      "type": "object",
      "required": ["event", "venue", "ticker", "timeframe", "kline"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "KlineUpdate" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "timeframe": { "type": "string" },
        "kline": { "$ref": "#/$defs/KlineMsg" }
      }
    },
    "Klines": {
      "type": "object",
      "required": ["event", "request_id", "venue", "ticker", "timeframe", "klines"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "Klines" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "timeframe": { "type": "string" },
        "klines": {
          "type": "array",
          "items": { "$ref": "#/$defs/KlineMsg" }
        }
      }
    },
    "DepthLevel": {
      "type": "object",
      "required": ["price", "qty"],
      "additionalProperties": false,
      "properties": {
        "price": { "type": "string" },
        "qty": { "type": "string" }
      }
    },
    "DepthSnapshot": {
      "type": "object",
      "required": ["event", "venue", "ticker", "stream_session_id", "sequence_id", "bids", "asks"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "DepthSnapshot" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream_session_id": { "type": "string" },
        "sequence_id": { "type": "integer" },
        "bids": { "type": "array", "items": { "$ref": "#/$defs/DepthLevel" } },
        "asks": { "type": "array", "items": { "$ref": "#/$defs/DepthLevel" } },
        "checksum": { "type": ["integer", "null"] }
      }
    },
    "DepthDiff": {
      "type": "object",
      "required": ["event", "venue", "ticker", "stream_session_id", "sequence_id", "prev_sequence_id", "bids", "asks"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "DepthDiff" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream_session_id": { "type": "string" },
        "sequence_id": { "type": "integer" },
        "prev_sequence_id": { "type": "integer" },
        "bids": { "type": "array", "items": { "$ref": "#/$defs/DepthLevel" } },
        "asks": { "type": "array", "items": { "$ref": "#/$defs/DepthLevel" } }
      }
    },
    "DepthGap": {
      "type": "object",
      "required": ["event", "venue", "ticker", "stream_session_id"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "DepthGap" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream_session_id": { "type": "string" }
      }
    },
    "OpenInterest": {
      "type": "object",
      "required": ["event", "request_id", "venue", "ticker", "data"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OpenInterest" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ts_ms", "open_interest"],
            "properties": {
              "ts_ms": { "type": "integer" },
              "open_interest": { "type": "string" }
            }
          }
        }
      }
    },
    "TickerInfo": {
      "type": "object",
      "required": ["event", "request_id", "venue", "tickers"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "TickerInfo" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "tickers": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "TickerStats": {
      "type": "object",
      "required": ["event", "request_id", "venue", "ticker", "stats"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "TickerStats" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stats": { "type": "object" }
      }
    },
    "Error": {
      "type": "object",
      "required": ["event", "code", "message"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "Error" },
        "request_id": { "type": ["string", "null"] },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "VenueReady": {
      "description": "Idempotent: emitted after every successful startup_login. Consumers must NOT trigger fresh subscriptions on receipt — ProcessManager owns resubscribe.",
      "type": "object",
      "required": ["event", "venue"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "VenueReady" },
        "venue": { "type": "string" },
        "request_id": { "$ref": "#/$defs/RequestIdNullable" }
      }
    },
    "VenueError": {
      "description": "Venue-scoped error. `message` is user-facing and authored by Python (F-Banner1); the Rust UI displays it verbatim and does NOT compose its own banner text. `code` drives severity & action button only.",
      "type": "object",
      "required": ["event", "venue", "code", "message"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "VenueError" },
        "venue": { "type": "string" },
        "request_id": { "$ref": "#/$defs/RequestIdNullable" },
        "code": {
          "type": "string",
          "enum": [
            "session_expired",
            "unread_notices",
            "phone_auth_required",
            "login_failed",
            "ticker_not_found",
            "transport_error"
          ]
        },
        "message": { "type": "string" }
      }
    },
    "VenueLoginStarted": {
      "description": "Python has spawned the venue's login helper subprocess (Tachibana = tkinter dialog).",
      "type": "object",
      "required": ["event", "venue"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "VenueLoginStarted" },
        "venue": { "type": "string" },
        "request_id": { "$ref": "#/$defs/RequestIdNullable" }
      }
    },
    "VenueLoginCancelled": {
      "type": "object",
      "required": ["event", "venue"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "VenueLoginCancelled" },
        "venue": { "type": "string" },
        "request_id": { "$ref": "#/$defs/RequestIdNullable" }
      }
    },
    "SecondPasswordRequired": {
      "description": "Python needs the second password before it can process a SubmitOrder request. Rust must display the second-password modal and respond with SetSecondPassword. tachibana 専用イベント。複数 venue サポート時は venue フィールドを追加すること。",
      "type": "object",
      "required": ["event", "request_id"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "SecondPasswordRequired" },
        "request_id": { "type": "string" }
      }
    },
    "OrderSubmitted": {
      "description": "Order has been forwarded to the venue's HTTP API (before response). Emitted before OrderAccepted or OrderRejected.",
      "type": "object",
      "required": ["event", "client_order_id", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderSubmitted" },
        "client_order_id": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderAccepted": {
      "description": "Venue accepted the order and assigned a venue_order_id. venue_order_id may be null on async acceptance paths.",
      "type": "object",
      "required": ["event", "client_order_id", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderAccepted" },
        "client_order_id": { "type": "string" },
        "venue_order_id": { "type": ["string", "null"] },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderRejected": {
      "description": "Order was rejected before or after acceptance (also covers modify/cancel rejection). reason_code is SCREAMING_SNAKE_CASE (spec.md §5.2).",
      "type": "object",
      "required": ["event", "client_order_id", "reason_code", "reason_text", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderRejected" },
        "client_order_id": { "type": "string" },
        "reason_code": {
          "description": "SCREAMING_SNAKE_CASE reject reason. Known values: UNSUPPORTED_IN_PHASE_O0, NOT_LOGGED_IN, TRANSPORT_ERROR, SESSION_EXPIRED, SECOND_PASSWORD_REQUIRED, SECOND_PASSWORD_LOCKED, SECOND_PASSWORD_INVALID, INSUFFICIENT_FUNDS, VENUE_UNSUPPORTED, RATE_LIMITED, INTERNAL_ERROR.",
          "type": "string"
        },
        "reason_text": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderPendingUpdate": {
      "description": "Modify request forwarded to venue; awaiting confirmation.",
      "type": "object",
      "required": ["event", "client_order_id", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderPendingUpdate" },
        "client_order_id": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderPendingCancel": {
      "description": "Cancel request forwarded to venue; awaiting confirmation.",
      "type": "object",
      "required": ["event", "client_order_id", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderPendingCancel" },
        "client_order_id": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderFilled": {
      "description": "Order was fully or partially filled. leaves_qty='0' means full fill (nautilus convention). Emitted by EC frame parser (Phase O2).",
      "type": "object",
      "required": ["event", "client_order_id", "venue_order_id", "trade_id", "last_qty", "last_price", "cumulative_qty", "leaves_qty", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderFilled" },
        "client_order_id": { "type": "string" },
        "venue_order_id": { "type": "string" },
        "trade_id": { "type": "string" },
        "last_qty": { "type": "string" },
        "last_price": { "type": "string" },
        "cumulative_qty": { "type": "string" },
        "leaves_qty": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderCanceled": {
      "description": "Order was successfully canceled.",
      "type": "object",
      "required": ["event", "client_order_id", "venue_order_id", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderCanceled" },
        "client_order_id": { "type": "string" },
        "venue_order_id": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderExpired": {
      "description": "Order expired (GTD past expiry date, or AT_THE_CLOSE past closing time).",
      "type": "object",
      "required": ["event", "client_order_id", "venue_order_id", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderExpired" },
        "client_order_id": { "type": "string" },
        "venue_order_id": { "type": "string" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "OrderListUpdated": {
      "description": "Response to GetOrderList — today's order records from the venue.",
      "type": "object",
      "required": ["event", "request_id", "orders"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "OrderListUpdated" },
        "request_id": { "type": "string" },
        "orders": {
          "type": "array",
          "items": { "$ref": "#/$defs/OrderRecordWire" }
        }
      }
    },
    "OrderSide": {
      "description": "Nautilus SCREAMING_SNAKE_CASE order side.",
      "type": "string",
      "enum": ["BUY", "SELL"]
    },
    "OrderType": {
      "description": "Nautilus SCREAMING_SNAKE_CASE order type.",
      "type": "string",
      "enum": ["MARKET", "LIMIT", "STOP_MARKET", "STOP_LIMIT", "MARKET_IF_TOUCHED", "LIMIT_IF_TOUCHED"]
    },
    "TimeInForce": {
      "description": "Nautilus SCREAMING_SNAKE_CASE time-in-force.",
      "type": "string",
      "enum": ["DAY", "GTC", "GTD", "IOC", "FOK", "AT_THE_OPEN", "AT_THE_CLOSE"]
    },
    "OrderStatus": {
      "description": "Nautilus SCREAMING_SNAKE_CASE order status.",
      "type": "string",
      "enum": ["INITIALIZED", "SUBMITTED", "ACCEPTED", "PARTIALLY_FILLED", "FILLED", "PENDING_UPDATE", "PENDING_CANCEL", "CANCELED", "EXPIRED", "REJECTED"]
    },
    "OrderRecordWire": {
      "description": "Single order record from GetOrderList. deny_unknown_fields (C-2).",
      "type": "object",
      "required": ["venue_order_id", "instrument_id", "order_side", "order_type", "quantity", "filled_qty", "leaves_qty", "time_in_force", "status", "ts_event_ms"],
      "additionalProperties": false,
      "properties": {
        "client_order_id": { "type": ["string", "null"] },
        "venue_order_id": { "type": "string" },
        "instrument_id": { "type": "string" },
        "order_side": { "$ref": "#/$defs/OrderSide" },
        "order_type": { "$ref": "#/$defs/OrderType" },
        "quantity": { "type": "string" },
        "filled_qty": { "type": "string" },
        "leaves_qty": { "type": "string" },
        "price": { "type": ["string", "null"] },
        "trigger_price": { "type": ["string", "null"] },
        "time_in_force": { "$ref": "#/$defs/TimeInForce" },
        "expire_time_ns": { "type": ["integer", "null"] },
        "status": { "$ref": "#/$defs/OrderStatus" },
        "ts_event_ms": { "type": "integer" }
      }
    },
    "BuyingPowerUpdated": {
      "description": "Response to GetBuyingPower. Contains current cash and credit buying power. Schema MINOR=2.",
      "type": "object",
      "required": ["event", "request_id", "venue", "cash_available", "cash_shortfall", "credit_available", "ts_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "BuyingPowerUpdated" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "cash_available": { "type": "integer" },
        "cash_shortfall": { "type": "integer", "minimum": 0 },
        "credit_available": { "type": "integer" },
        "ts_ms": { "type": "integer" }
      }
    },
    "PositionRecordWire": {
      "description": "Single position entry (cash or margin) in PositionsUpdated. Schema MINOR=7.",
      "type": "object",
      "required": ["instrument_id", "qty", "market_value", "position_type", "venue"],
      "additionalProperties": false,
      "properties": {
        "instrument_id": { "type": "string" },
        "qty": { "type": "string" },
        "market_value": { "type": "string" },
        "position_type": {
          "type": "string",
          "enum": ["cash", "margin_credit", "margin_general"]
        },
        "tategyoku_id": { "type": ["string", "null"] },
        "venue": { "type": "string", "const": "tachibana" }
      }
    },
    "PositionsUpdated": {
      "description": "Response to GetPositions. Contains current positions held at the venue. Schema MINOR=7.",
      "type": "object",
      "required": ["event", "request_id", "venue", "positions", "ts_ms"],
      "additionalProperties": false,
      "properties": {
        "event": { "const": "PositionsUpdated" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "positions": {
          "type": "array",
          "items": { "$ref": "#/$defs/PositionRecordWire" }
        },
        "ts_ms": { "type": "integer" }
      }
    }
  }
}
