{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowsurface/ipc/commands",
  "title": "Rust → Python IPC Commands",
  "description": "Commands sent from the Rust viewer to the Python data engine. Schema MAJOR=2.",
  "oneOf": [
    { "$ref": "#/$defs/Hello" },
    { "$ref": "#/$defs/SetProxy" },
    { "$ref": "#/$defs/Subscribe" },
    { "$ref": "#/$defs/Unsubscribe" },
    { "$ref": "#/$defs/FetchKlines" },
    { "$ref": "#/$defs/FetchTrades" },
    { "$ref": "#/$defs/FetchOpenInterest" },
    { "$ref": "#/$defs/FetchTickerStats" },
    { "$ref": "#/$defs/ListTickers" },
    { "$ref": "#/$defs/GetTickerMetadata" },
    { "$ref": "#/$defs/RequestDepthSnapshot" },
    { "$ref": "#/$defs/Shutdown" },
    { "$ref": "#/$defs/Ping" },
    { "$ref": "#/$defs/RequestVenueLogin" },
    { "$ref": "#/$defs/SetSecondPassword" },
    { "$ref": "#/$defs/ForgetSecondPassword" },
    { "$ref": "#/$defs/SubmitOrder" },
    { "$ref": "#/$defs/ModifyOrder" },
    { "$ref": "#/$defs/CancelOrder" },
    { "$ref": "#/$defs/CancelAllOrders" },
    { "$ref": "#/$defs/GetOrderList" },
    { "$ref": "#/$defs/GetBuyingPower" },
    { "$ref": "#/$defs/GetPositions" }
  ],
  "$defs": {
    "RequestId": {
      "description": "UUIDv4 string per RFC 4122 (LOW-1 / F-L7). Python emits via str(uuid.uuid4()) — hyphenated lowercase.",
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "maxLength": 36
    },
    "Hello": {
      "type": "object",
      "required": ["op", "schema_major", "schema_minor", "client_version", "token"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "Hello" },
        "schema_major": { "type": "integer", "minimum": 0 },
        "schema_minor": { "type": "integer", "minimum": 0 },
        "client_version": { "type": "string" },
        "token": { "type": "string", "minLength": 1 }
      }
    },
    "SetProxy": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "SetProxy" },
        "url": { "type": ["string", "null"] }
      }
    },
    "Subscribe": {
      "type": "object",
      "required": ["op", "venue", "ticker", "stream"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "Subscribe" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream": {
          "type": "string",
          "enum": ["trade", "depth", "kline"]
        },
        "timeframe": { "type": ["string", "null"] },
        "market": { "type": ["string", "null"] }
      }
    },
    "Unsubscribe": {
      "type": "object",
      "required": ["op", "venue", "ticker", "stream"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "Unsubscribe" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "stream": { "type": "string" },
        "market": { "type": ["string", "null"] }
      }
    },
    "FetchKlines": {
      "type": "object",
      "required": ["op", "request_id", "venue", "ticker", "timeframe", "limit"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "FetchKlines" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "timeframe": { "type": "string" },
        "limit": { "type": "integer", "minimum": 1 },
        "start_ms": { "type": ["integer", "null"] },
        "end_ms": { "type": ["integer", "null"] },
        "market": { "type": ["string", "null"] }
      }
    },
    "FetchTrades": {
      "type": "object",
      "required": ["op", "request_id", "venue", "ticker", "start_ms", "end_ms"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "FetchTrades" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "start_ms": { "type": "integer" },
        "end_ms": { "type": "integer" },
        "market": { "type": ["string", "null"] },
        "data_path": { "type": ["string", "null"] }
      }
    },
    "FetchOpenInterest": {
      "type": "object",
      "required": ["op", "request_id", "venue", "ticker", "timeframe", "limit"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "FetchOpenInterest" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "timeframe": { "type": "string" },
        "limit": { "type": "integer", "minimum": 1 },
        "start_ms": { "type": ["integer", "null"] },
        "end_ms": { "type": ["integer", "null"] },
        "market": { "type": ["string", "null"] }
      }
    },
    "FetchTickerStats": {
      "type": "object",
      "required": ["op", "request_id", "venue", "ticker"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "FetchTickerStats" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "market": { "type": ["string", "null"] }
      }
    },
    "ListTickers": {
      "type": "object",
      "required": ["op", "request_id", "venue"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "ListTickers" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "market": { "type": ["string", "null"] }
      }
    },
    "GetTickerMetadata": {
      "type": "object",
      "required": ["op", "request_id", "venue", "ticker"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "GetTickerMetadata" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" }
      }
    },
    "RequestDepthSnapshot": {
      "type": "object",
      "required": ["op", "request_id", "venue", "ticker"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "RequestDepthSnapshot" },
        "request_id": { "type": "string" },
        "venue": { "type": "string" },
        "ticker": { "type": "string" },
        "market": { "type": ["string", "null"] }
      }
    },
    "Shutdown": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "Shutdown" }
      }
    },
    "Ping": {
      "type": "object",
      "required": ["op", "request_id"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "Ping" },
        "request_id": { "$ref": "#/$defs/RequestId" }
      }
    },
    "RequestVenueLogin": {
      "description": "Rust UI asks the engine to drive a venue-specific login flow (Tachibana spawns a tkinter helper subprocess).",
      "type": "object",
      "required": ["op", "request_id", "venue"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "RequestVenueLogin" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" }
      }
    },
    "SetSecondPassword": {
      "description": "Send the second password to Python memory for the next order submission. `value` is the raw secret; Python wraps it in SecretStr immediately. Debug output masks `value` as [REDACTED] (D2-M5).",
      "type": "object",
      "required": ["op", "request_id", "value"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "SetSecondPassword" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "ForgetSecondPassword": {
      "description": "Explicitly clear the second password from Python memory (idle forget / explicit logout).",
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "ForgetSecondPassword" }
      }
    },
    "SubmitOrder": {
      "description": "Submit a new order to the venue. `order` shape matches the nautilus OrderFactory input (spec.md §5).",
      "type": "object",
      "required": ["op", "request_id", "venue", "order"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "SubmitOrder" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" },
        "order": { "$ref": "#/$defs/SubmitOrderRequest" }
      }
    },
    "ModifyOrder": {
      "description": "Modify price / qty / trigger / expire of an existing order. `request_key` は不要（WAL 冪等は submit 専用。ModifyOrder/CancelOrder は WAL スコープ外）。",
      "type": "object",
      "required": ["op", "request_id", "venue", "client_order_id", "change"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "ModifyOrder" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" },
        "client_order_id": { "type": "string" },
        "venue_order_id": { "type": ["string", "null"] },
        "change": { "$ref": "#/$defs/OrderModifyChange" }
      }
    },
    "CancelOrder": {
      "description": "Cancel a specific order. Rust looks up venue_order_id via OrderSessionState before sending. `request_key` は不要（WAL 冪等は submit 専用。ModifyOrder/CancelOrder は WAL スコープ外）。",
      "type": "object",
      "required": ["op", "request_id", "venue", "client_order_id", "venue_order_id"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "CancelOrder" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" },
        "client_order_id": { "type": "string" },
        "venue_order_id": { "type": "string" }
      }
    },
    "CancelAllOrders": {
      "description": "Cancel all open orders for a venue, optionally filtered by instrument and side.",
      "type": "object",
      "required": ["op", "request_id", "venue"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "CancelAllOrders" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" },
        "instrument_id": { "type": ["string", "null"] },
        "order_side": {
          "oneOf": [
            { "$ref": "#/$defs/OrderSide" },
            { "type": "null" }
          ]
        }
      }
    },
    "GetOrderList": {
      "description": "Fetch today's order list from the venue.",
      "type": "object",
      "required": ["op", "request_id", "venue", "filter"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "GetOrderList" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" },
        "filter": { "$ref": "#/$defs/OrderListFilter" }
      }
    },
    "GetBuyingPower": {
      "description": "Fetch current buying power (cash + credit) from the venue. Added in schema MINOR=2.",
      "type": "object",
      "required": ["op", "request_id", "venue"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "GetBuyingPower" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" }
      }
    },
    "GetPositions": {
      "description": "Fetch current positions (cash + margin) from the venue. Added in schema MINOR=7.",
      "type": "object",
      "required": ["op", "request_id", "venue"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "GetPositions" },
        "request_id": { "$ref": "#/$defs/RequestId" },
        "venue": { "type": "string" }
      }
    },
    "OrderSide": {
      "description": "Nautilus SCREAMING_SNAKE_CASE order side.",
      "type": "string",
      "enum": ["BUY", "SELL"]
    },
    "OrderType": {
      "description": "Nautilus SCREAMING_SNAKE_CASE order type.",
      "type": "string",
      "enum": ["MARKET", "LIMIT", "STOP_MARKET", "STOP_LIMIT", "MARKET_IF_TOUCHED", "LIMIT_IF_TOUCHED"]
    },
    "TimeInForce": {
      "description": "Nautilus SCREAMING_SNAKE_CASE time-in-force.",
      "type": "string",
      "enum": ["DAY", "GTC", "GTD", "IOC", "FOK", "AT_THE_OPEN", "AT_THE_CLOSE"]
    },
    "TriggerType": {
      "description": "Nautilus SCREAMING_SNAKE_CASE stop-order trigger type. Only LAST is supported in Phase O0-O3.",
      "type": "string",
      "enum": ["LAST", "BID_ASK", "INDEX"]
    },
    "SubmitOrderRequest": {
      "description": "Order placement payload — fields match nautilus OrderFactory. deny_unknown_fields prevents second_password / p_no injection via IPC (C-R2-M3 / D3-1).",
      "type": "object",
      "required": [
        "client_order_id", "instrument_id", "order_side", "order_type",
        "quantity", "time_in_force", "post_only", "reduce_only", "tags"
      ],
      "additionalProperties": false,
      "properties": {
        "client_order_id": {
          "description": "ASCII printable, 1–36 chars (spec.md §5).",
          "type": "string",
          "minLength": 1,
          "maxLength": 36
        },
        "instrument_id": {
          "description": "Format: '<code>.<suffix>/<venue>' e.g. '7203.T/TSE'.",
          "type": "string"
        },
        "order_side": { "$ref": "#/$defs/OrderSide" },
        "order_type": { "$ref": "#/$defs/OrderType" },
        "quantity": { "type": "string" },
        "price": { "type": ["string", "null"] },
        "trigger_price": { "type": ["string", "null"] },
        "trigger_type": {
          "oneOf": [
            { "$ref": "#/$defs/TriggerType" },
            { "type": "null" }
          ]
        },
        "time_in_force": { "$ref": "#/$defs/TimeInForce" },
        "expire_time_ns": { "type": ["integer", "null"] },
        "post_only": { "type": "boolean" },
        "reduce_only": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "request_key": {
          "description": "xxh3_64 hash of canonical order, computed by Rust. 0 = unknown. Used for WAL idempotency restore (architecture.md §4.1).",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "OrderModifyChange": {
      "description": "Fields to modify on an existing order; null = unchanged. deny_unknown_fields (C-R2-M3).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "new_quantity": { "type": ["string", "null"] },
        "new_price": { "type": ["string", "null"] },
        "new_trigger_price": { "type": ["string", "null"] },
        "new_expire_time_ns": { "type": ["integer", "null"] }
      }
    },
    "OrderListFilter": {
      "description": "Filter criteria for GetOrderList. All fields optional.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "type": ["string", "null"] },
        "instrument_id": { "type": ["string", "null"] },
        "date": { "type": ["string", "null"] }
      }
    }
  }
}
